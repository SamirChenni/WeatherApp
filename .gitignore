# ==========================================================================
# SkyCast Monorepo Root GitIgnore
# ==========================================================================

# 1. Dependency Directories (Blocks both folders at once)
**/node_modules/
**/jspm_packages/
**/web_modules/

# 2. Local Environment / Secret Keys
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
**/*.env.*

# 3. Frontend Build Output (Vite/React)
**/dist/
**/build/
**/out/

# 4. OS / System Metadata Files
.DS_Store
Thumbs.db
Desktop.ini
**/.DS_Store

# 5. IDE & Editor Specific Configurations
**/.vscode/
**/.idea/
**/*.suo
**/*.ntvs*
**/*.njsproj
**/*.sln
**/*.swp

# 6. Diagnostic Logs & Run Caches
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*
**/.eslintcache
**/.turbo/